# Quarto
/.quarto/
/_site/
/.local-archive/
/.quarto-local/

# Secrets - never commit local keys. .env.example (no real keys) stays tracked.
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
ENV/

# IDE and agent-local state
.vscode/
.idea/
.claude/

# OS
.DS_Store
Thumbs.db

# Regenerable raw FRED single-series cache (jobs posts re-fetch live and CI
# renders from the committed _freeze/). Matches only top-level data/*.csv, so
# cleaned data under data/clean/ and raw sources under data/raw/ that a post
# renders from are still tracked. Rebuild with scripts/download_fred_data.py.
posts/*/data/*.csv

# Misc
*.log

**/*.quarto_ipynb
